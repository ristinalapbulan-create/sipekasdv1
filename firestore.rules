rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isLoggedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isDisdik() {
      return isLoggedIn() && getUserData().role == 'disdik';
    }
    
    function getUserNpsn() {
      return getUserData().npsn;
    }
    
    function isValidReport() {
      let incoming = request.resource.data;
      return incoming.keys().hasAll(['link_jurnal', 'link_daftar_hadir', 'link_dokumentasi']) &&
             incoming.link_jurnal.matches('^https://.*') &&
             incoming.link_daftar_hadir.matches('^https://.*') &&
             incoming.link_dokumentasi.matches('^https://.*');
    }

    match /users/{userId} {
      allow read: if isLoggedIn() && (isDisdik() || request.auth.uid == userId);
      allow write: if isDisdik();
    }

    match /reports/{reportId} {
      allow read: if isLoggedIn() && (isDisdik() || resource.data.npsn_sekolah == getUserNpsn());
      allow create: if isLoggedIn() && (isDisdik() || (request.resource.data.npsn_sekolah == getUserNpsn() && isValidReport()));
      allow update: if isLoggedIn() && (isDisdik() || (resource.data.npsn_sekolah == getUserNpsn() && isValidReport()));
      allow delete: if isLoggedIn() && (isDisdik() || (resource.data.npsn_sekolah == getUserNpsn() && resource.data.status == 'Menunggu'));
    }

    match /decrees/{decreeId} {
      allow read: if isLoggedIn();
      allow write: if isDisdik();
    }

    match /documentations/{docId} {
      allow read: if isLoggedIn();
      allow write: if isDisdik();
    }
  }
}
