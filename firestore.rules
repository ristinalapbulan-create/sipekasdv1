rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isDisdik() {
      return isSignedIn() && getUserRole() == 'disdik';
    }

    function isSekolah() {
      return isSignedIn() && getUserRole() == 'sekolah';
    }

    function isOwner(npsn) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.npsn == npsn;
    }

    // ── USERS ─────────────────────────────────────────────────────────
    match /users/{uid} {
      // Portal publik butuh baca data sekolah untuk statistik
      allow read: if true;
      // Hanya disdik yang bisa tulis (admin manage users)
      allow write: if isDisdik() || request.auth.uid == uid;
    }

    // ── LAPORAN ───────────────────────────────────────────────────────
    match /reports/{reportId} {
      // Portal publik butuh baca laporan untuk metrik
      allow read: if true;

      // Sekolah bisa buat laporan baru untuk NPSN-nya sendiri
      allow create: if isSekolah() &&
                      request.resource.data.npsn_sekolah ==
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.npsn;

      // Sekolah bisa hapus laporan milik sendiri yang statusnya Menunggu
      allow delete: if isSekolah() &&
                      resource.data.npsn_sekolah ==
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.npsn &&
                      resource.data.status == 'Menunggu';

      // Hanya disdik bisa update status laporan (verifikasi/revisi)
      allow update: if isDisdik() ||
                    (isSekolah() &&
                      resource.data.npsn_sekolah ==
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.npsn &&
                      resource.data.status == 'Revisi');
    }

    // ── SK DISDIK ─────────────────────────────────────────────────────
    match /sk_documents/{skId} {
      // Semua user yang login bisa baca SK
      allow read: if isSignedIn();
      // Hanya disdik bisa tambah / hapus SK
      allow create, update, delete: if isDisdik();
    }

    // ── DOKUMENTASI ───────────────────────────────────────────────────
    match /dokumentasi/{docId} {
      // Semua user yang login bisa baca galeri dokumentasi
      allow read: if isSignedIn();
      // Hanya disdik bisa kelola dokumentasi
      allow create, update, delete: if isDisdik();
    }
  }
}
